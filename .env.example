# Required: OpenAI API key for LLM-powered reviews
OPENAI_API_KEY=

# Optional: Override the default LLM model (default: gpt-4.1-mini)
# LLM_MODEL=

# Optional: Override the model used for the final judge verdict (default: gpt-4.1)
# LLM_VERDICT_MODEL=

# Optional: Tavily API key for agentic web research (free: 1,000 searches/month)
# Get yours at https://tavily.com — enables agents to search the web for real market data
# TAVILY_API_KEY=

# Optional: MySQL connection string for user persistence
# DATABASE_URL=mysql://user:password@localhost:3306/reject_me_first

# Optional: JWT secret for session cookies
# JWT_SECRET=

# Optional: Manus OAuth (only needed for Manus deployment)
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
# OWNER_OPEN_ID=

# Optional: Forge storage proxy (only needed for Manus deployment)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

